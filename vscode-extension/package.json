{
  "name": "agentcarousel-fixture-navigator",
  "displayName": "AgentCarousel Fixtures",
  "description": "Quality Assurance and Trust for Autonomous AI — navigate, inspect, and understand your AgentCarousel fixture files with a rich, human-readable interface right inside your editor.",
  "version": "0.1.0",
  "publisher": "agentcarousel",
  "license": "MIT",
  "homepage": "https://agentcarousel.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentcarousel/agentcarousel"
  },
  "bugs": {
    "url": "https://github.com/agentcarousel/agentcarousel/issues"
  },
  "keywords": [
    "agentcarousel",
    "ai agents",
    "evaluation",
    "fixtures",
    "testing",
    "llm",
    "certification",
    "nist",
    "cmmc",
    "yaml"
  ],
  "categories": [
    "Testing",
    "Visualization",
    "Other"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "workspaceContains:fixtures/**/*.yaml"
  ],
  "main": "./out/extension.js",
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentcarousel",
          "title": "AgentCarousel",
          "icon": "media/carousel.svg"
        }
      ]
    },
    "views": {
      "agentcarousel": [
        {
          "id": "agentcarousel-fixtures",
          "name": "Fixtures",
          "icon": "media/carousel.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "agentcarousel-fixtures",
        "contents": "No fixture files found.\n\nAgentCarousel fixtures live in `fixtures/skills/**/*.yaml`. Open a workspace that contains them, or adjust your glob pattern.\n\n[Configure Fixture Glob](command:agentcarousel.configureGlob)\n\n[Learn more at agentcarousel.com](https://agentcarousel.com)"
      }
    ],
    "commands": [
      {
        "command": "agentcarousel.refreshFixtures",
        "title": "Refresh Fixtures",
        "icon": "$(refresh)",
        "category": "AgentCarousel"
      },
      {
        "command": "agentcarousel.showCaseDetail",
        "title": "Show Case Detail",
        "category": "AgentCarousel"
      },
      {
        "command": "agentcarousel.openInEditor",
        "title": "Open in Editor",
        "category": "AgentCarousel"
      },
      {
        "command": "agentcarousel.configureGlob",
        "title": "Configure Fixture Glob",
        "category": "AgentCarousel"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentcarousel.refreshFixtures",
          "when": "view == agentcarousel-fixtures",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "AgentCarousel",
      "properties": {
        "agentcarousel.fixtureGlob": {
          "type": "string",
          "default": "fixtures/skills/**/*.yaml",
          "description": "Glob pattern for fixture YAML files (relative to workspace root).",
          "order": 1
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
